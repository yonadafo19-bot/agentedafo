{
  "name": "open-gravity",
  "version": "1.0.0",
  "description": "Agente de IA personal con Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "google-auth": "tsx src/infrastructure/scripts/google-auth.ts",
    "restructure:create-folders": "bash scripts/restructure/create-folders.sh",
    "restructure:migrate": "bash scripts/restructure/migrate.sh"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "doc": "^0.0.3",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "firebase-admin": "^13.7.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^9.15.1",
    "googleapis": "^140.0.1",
    "grammy": "^1.36.2",
    "groq-sdk": "^0.8.0",
    "openai": "^4.80.3",
    "pdfkit": "^0.17.2",
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pdfkit": "^0.17.5",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
