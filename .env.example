# Telegram
TELEGRAM_BOT_TOKEN="SUSTITUYE_POR_EL_TUYO"
TELEGRAM_ALLOWED_USER_IDS="SUSTITUYE_POR_EL_TUYO"

# OpenAI (RECOMENDADO - Mejor calidad y soporta herramientas perfectamente)
# Obtén tu API key: https://platform.openai.com/api-keys
OPENAI_API_KEY="SUSTITUYE_POR_EL_TUYO"
OPENAI_MODEL="gpt-4o-mini"

# Brave Search (búsqueda web privada - recomendado)
# Obtén tu API Key gratis: https://api.search.brave.com/app/keys
BRAVE_API_KEY="SUSTITUYE_POR_EL_TUYO"

# Google Search (para búsqueda web)
# Obtén API Key: https://console.cloud.google.com/apis/credentials
# Obtén Search Engine ID: https://cse.google.com/cse/all
GOOGLE_API_KEY="SUSTITUYE_POR_EL_TUYO"
GOOGLE_SEARCH_ENGINE_ID="SUSTITUYE_POR_EL_TUYO"

# LLM Providers
GROQ_API_KEY="SUSTITUYE_POR_EL_TUYO"
GROQ_MODEL="llama-3.3-70b-versatile"

OPENROUTER_API_KEY="SUSTITUYE_POR_EL_TUYO"
OPENROUTER_MODEL="google/gemma-3-27b-it:free"

# Base de datos
DB_PATH="./memory.db"

# Google Cloud / Firebase
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# Firebase Configuration
# Para usar Firebase, coloca tu archivo service-account.json en la raíz del proyecto
# FIREBASE_SERVICE_ACCOUNT puede quedar vacío si usas el archivo
FIREBASE_SERVICE_ACCOUNT='' # Opcional: JSON completo del service account
FIREBASE_DATABASE_URL="https://tu-proyecto-id.firebaseio.com" # URL de Realtime Database
FIREBASE_STORAGE_BUCKET="tu-proyecto-id.appspot.com" # Nombre del bucket de Storage

# Configuración del agente
MAX_AGENT_ITERATIONS=5
AGENT_TIMEOUT_MS=120000

# ElevenLabs (Texto a Voz)
ELEVENLABS_API_KEY="SUSTITUYE_POR_EL_TUYO"
ELEVENLABS_VOICE_ID="iP95p4xoKVk53GoZ742B" # Chris - Voz masculina encantadora, natural y down-to-earth
ELEVENLABS_MODEL="eleven_multilingual_v2"
